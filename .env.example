# =============================================================================
# Environment variables for the DevSecOps local stack
#
# USAGE:
#   copy .env.example .env
#   Then fill in every value before running docker-compose up or npm start.
#
# SECURITY: Never commit .env to git — it is already in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Application — required at runtime
# ---------------------------------------------------------------------------

# Strong random key (minimum 32 characters) that protects the POST /toggle-health
# endpoint. Anyone who calls that endpoint must send this value in X-API-Key header.
# Generate with PowerShell: -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 32 | % {[char]$_})
ADMIN_API_KEY=

# TCP port the Express app listens on (default 3000)
PORT=3001

# ---------------------------------------------------------------------------
# Jenkins — required when starting the Jenkins container
# ---------------------------------------------------------------------------

# Jenkins web UI admin username
JENKINS_ADMIN_USER=admin

# Jenkins admin password — minimum 16 characters, use a strong random value.
# Generate with: openssl rand -base64 24
JENKINS_ADMIN_PASSWORD=12345

# ---------------------------------------------------------------------------
# AWS — used by the Jenkins pipeline and local AWS CLI operations
# ---------------------------------------------------------------------------

# Your 12-digit AWS account ID
AWS_ACCOUNT_ID=395069634073

# AWS region where the ECS cluster and ECR repo live
AWS_REGION=ap-south-1
AWS_DEFAULT_REGION=ap-south-1

# ECR repository URI (output by Terraform after Phase 2)
ECR_REPOSITORY=395069634073.dkr.ecr.ap-south-1.amazonaws.com/devsecops-app

# ECS cluster and service names
ECS_CLUSTER=devsecops-app-cluster
ECS_SERVICE=devsecops-app-service

# ---------------------------------------------------------------------------
# SonarQube — used for local SAST analysis
# ---------------------------------------------------------------------------

# The token you generated at Administration > Security > Tokens in SonarQube
# Default SonarQube credentials on first start: admin / admin (change immediately)
SONAR_TOKEN=

# SonarQube base URL (default for local Docker Compose stack)
SONARQUBE_URL=http://localhost:9000
