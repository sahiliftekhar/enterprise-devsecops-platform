{
  "name": "devsecops-app",
  "version": "1.0.0",
  "description": "Secure DevSecOps Express microservice \u2014 CI/CD pipeline dissertation project",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "sonar": "sonar-scanner",
    "audit:check": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^3.4.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": true,
    "clearMocks": true,
    "testTimeout": 10000,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "*.js",
      "!node_modules/**",
      "!jest.config.js",
      "!**/*.test.js",
      "!**/*.spec.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "clover",
      "json"
    ],
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  }
}
